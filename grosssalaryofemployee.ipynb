salary=float(input("Enter the salary:"))
hra=salary*0.1
ta=salary*5/100
total_salary=salary+hra+ta
tax=total_salary*2/100
net_salary=total_salary-tax
print("Net salary of the employee is:", net_salary)
print("HRA(Home rent allowance) is:", hra)
print("TA(travelling allowance) is:", ta)
print("Tax is:", tax)
print("Total salary before tax subtraction:", total_salary)
